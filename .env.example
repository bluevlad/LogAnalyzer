# LogAnalyzer Environment Variables

# Database (loganalyzer_svc 계정 사용 — DB_ACCOUNT_POLICY.md 참조)
LA_DATABASE_URL=postgresql://loganalyzer_svc:<PASSWORD>@host.docker.internal:5432/loganalyzer

# Docker
LA_DOCKER_SOCKET=/var/run/docker.sock

# Log Collection
LA_LOG_COLLECT_INTERVAL_MINUTES=5
LA_LOG_RETENTION_DAYS=30
LA_AGGREGATE_RETENTION_DAYS=90

# Integration - StandUp
LA_STANDUP_API_URL=http://host.docker.internal:9060
LA_STANDUP_API_KEY=

# Integration - QA Dashboard
LA_QA_DASHBOARD_API_URL=http://host.docker.internal:9095
LA_QA_DASHBOARD_API_KEY=

# Integration - GitHub
LA_GITHUB_TOKEN=
LA_GITHUB_REPOS=bluevlad/AllergyInsight,bluevlad/HopenVision,bluevlad/EduFit

# Report
LA_DAILY_REPORT_HOUR=6
LA_ERROR_THRESHOLD_CRITICAL=10
LA_ERROR_THRESHOLD_HIGH=5
